{
  "name": "@gist/review",
  "version": "0.3.0",
  "description": "Approve website changes without reading code — local before/after capture, diff, and an AI walkthrough via your coding agent.",
  "license": "MIT",
  "type": "module",
  "files": [
    "bin/",
    "src/",
    "skill/",
    "README.md"
  ],
  "bin": {
    "gist": "bin/gist.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "gist": "tsx bin/gist.ts",
    "test": "tsx --test test/*.test.ts test/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "prepack": "cp README.md README.repo.md && cp README.npm.md README.md",
    "postpack": "mv README.repo.md README.md"
  },
  "dependencies": {
    "pixelmatch": "^7.2.0",
    "playwright": "^1.61.1",
    "pngjs": "^7.0.0",
    "tsx": "^4.23.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.5",
    "@types/pngjs": "^6.0.5",
    "typescript": "5.9"
  }
}
